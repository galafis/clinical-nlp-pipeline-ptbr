# Clinical NLP Pipeline - Variaveis de Ambiente
# Copie para .env e preencha os valores

# API
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_LOG_LEVEL=info

# Modelos
MODEL_NAME=neuralmind/bert-base-portuguese-cased
MODEL_CACHE_DIR=./data/models
MODEL_MAX_LENGTH=512
DEVICE=cpu

# Dados
DATA_DIR=./data
ANNOTATIONS_DIR=./data/annotations

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
